// ══════════════════════════════════════════════════════════
// ACİLX — Firestore Güvenlik Kuralları (Rol Bazlı)
// Başasistan: tüm koleksiyonlarda tam yetki
// Asistan: sadece kendi profilini okuyup düzenleyebilir
// ══════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı fonksiyonlar ─────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isBasasistan() {
      return isAuth() && getUserRole() == 'basasistan';
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Kullanıcılar ──────────────────────────────────
    // Başasistan: tüm kullanıcıları okuyabilir, yazabilir, silebilir
    // Asistan: sadece kendi profilini okuyabilir ve düzenleyebilir
    //          (rol alanını değiştiremez)
    match /users/{uid} {
      allow read: if isAuth() && (isOwner(uid) || isBasasistan());
      allow create: if isAuth() && isOwner(uid);
      allow update: if isAuth() && (
        (isOwner(uid) && !('role' in request.resource.data &&
          request.resource.data.role != resource.data.role)) ||
        isBasasistan()
      );
      allow delete: if isBasasistan();
    }

    // ── Nöbet çizelgeleri ─────────────────────────────
    // Herkes okuyabilir, sadece başasistan yazabilir
    match /schedules/{scheduleId} {
      allow read: if isAuth();
      allow write: if isBasasistan();
    }

    // ── Asistan tercihleri ────────────────────────────
    // Asistan kendi tercihini okur/yazar
    // Başasistan tüm tercihleri okuyabilir/yazabilir
    match /preferences/{prefId} {
      allow read: if isAuth() && (
        isBasasistan() ||
        prefId.matches(request.auth.uid + '_.*')
      );
      allow write: if isAuth() && (
        isBasasistan() ||
        prefId.matches(request.auth.uid + '_.*')
      );
      allow delete: if isBasasistan();
    }

    // ── Audit log ───────────────────────────────────
    // Sadece başasistan okuyabilir, herkes kayıt oluşturabilir,
    // güncelleme/silme yasak
    match /audit/{logId} {
      allow read: if isBasasistan();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
