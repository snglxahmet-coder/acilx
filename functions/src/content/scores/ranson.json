  "interpretationRanges": [
    {
      "min": 0,
      "max": 2,
      "label": "Hafif Pankreatit",
      "severity": "low",
      "recommendation": "Mortalite ~%1. Konservatif tedavi: IV hidrasyon, ağrı kontrolü, oral beslenmeye erken geçiş."
    },
    {
      "min": 3,
      "max": 5,
      "label": "Orta-Ağır Pankreatit",
      "severity": "moderate",
      "recommendation": "Mortalite ~%10–20. Yoğun izlem, agresif sıvı resüsitasyonu, BT ile komplikasyon değerlendirmesi. Gerekirse yoğun bakım."
    },
    {
      "min": 6,
      "max": 11,
      "label": "Ağır Pankreatit",
      "severity": "high",
      "recommendation": "Mortalite >%50. Yoğun bakımda takip, organ destek tedavileri, cerrahi konsültasyon (enfekte nekroz durumunda). Enteral beslenme tercihi."
    }
  ],
