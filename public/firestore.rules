// ══════════════════════════════════════════════════════════
// ACİLX — Firestore Güvenlik Kuralları
// Firebase Console → Firestore → Rules sekmesine yapıştır
// ══════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı fonksiyonlar ─────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isBasasistan() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'basasistan';
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Kullanıcılar ──────────────────────────────────
    // Herkes kendi kaydını okuyabilir.
    // Başasistan tüm kullanıcıları okuyabilir ve rol atayabilir.
    match /users/{uid} {
      allow read: if isAuth() && (isOwner(uid) || isBasasistan());
      allow create: if isAuth() && isOwner(uid);
      allow update: if isAuth() && (
        (isOwner(uid) && !('role' in request.resource.data &&
          request.resource.data.role != resource.data.role)) ||
        isBasasistan()
      );
      allow delete: if isBasasistan();
    }

    // ── Nöbet çizelgeleri ─────────────────────────────
    // Herkes okuyabilir (iframe'deki asistan kendi nöbetini görsün).
    // Sadece başasistan yazabilir.
    match /schedules/{scheduleId} {
      allow read: if isAuth();
      allow write: if isBasasistan();
    }

    // ── Asistan tercihleri ────────────────────────────
    // Format: preferences/{uid}_{year}_{month}
    // Asistan kendi tercihini okur/yazar.
    // Başasistan tüm tercihleri okuyabilir.
    match /preferences/{prefId} {
      allow read: if isAuth() && (
        isBasasistan() ||
        prefId.matches(request.auth.uid + '_.*')
      );
      allow write: if isAuth() && (
        isBasasistan() ||
        prefId.matches(request.auth.uid + '_.*')
      );
      allow delete: if isBasasistan();
    }

    // ── Audit log (ileride) ───────────────────────────
    match /audit/{logId} {
      allow read: if isBasasistan();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
